# Server
PORT=5000
NODE_ENV=development

# Database — PostgreSQL (mandatory, as per tech stack requirements)
# For a free cloud DB: https://supabase.com (copy the connection string fields below)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lead_management
DB_USER=postgres
DB_PASSWORD=yourpassword

# Set USE_SQLITE=true ONLY for local development without a PostgreSQL instance
# USE_SQLITE=true

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer - Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Lead Management <your@gmail.com>

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
